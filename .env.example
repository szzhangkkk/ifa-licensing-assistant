# ============================================================
# IFA 上牌小助手 (Lili Bot) - 环境配置
# 复制此文件为 .env 并填入实际值
#    cp .env.example .env
# ============================================================

# ---------- 镜像仓库配置 ----------
# 阿里云 ACR 容器镜像服务（个人版免费）
# 注册: https://cr.console.aliyun.com → 容器镜像服务
REGISTRY=registry.cn-hangzhou.aliyuncs.com
IMAGE_NAMESPACE=ifa
IMAGE_TAG=latest

# ---------- WorkTool 配置 ----------
# 机器人的 robotId，从 WorkTool 控制台获取
# 示例: wt60io33cv8091w4fzv8gajcfslw0nhr
WORKTOOL_ROBOT_ID=your_robot_id_here

# WorkTool API 地址（一般不需要改）
WORKTOOL_API_URL=https://api.worktool.ymdyes.cn/wework/sendRawMessage

# ---------- 向量数据库配置 ----------
# Milvus Lite 数据库路径（Docker 里用 /app/milvus.db）
MILVUS_DB_PATH=./milvus.db

# ChromaDB 降级备选路径（Milvus 不可用时自动切换）
CHROMA_DB_PATH=./chroma_db

# ---------- 企业微信 SDK 长连接（可选） ----------
# Bot ID (从企业微信管理后台获取)
WECOM_BOT_ID=

# Bot Secret (从企业微信管理后台获取)
WECOM_BOT_SECRET=

# ---------- ngrok 配置（不使用 Docker 时需要） ----------
# ngrok authtoken，注册 https://ngrok.com 获取
NGROK_AUTH_TOKEN=

# ---------- 服务器配置 ----------
# Flask 监听端口
FLASK_PORT=5000

# Flask 监听地址（Docker 用 0.0.0.0）
FLASK_HOST=0.0.0.0

# ---------- A1 表格链接（可根据实际更新） ----------
A1_FORM_URL=https://www.yuque.com/attachments/yuque/0/2026/pdf/28748258/1776425817432-dc71d778-7c33-409f-92f7-f1c690e5cea8.pdf
A1_GUIDE_URL=https://www.yuque.com/attachments/yuque/0/2026/pdf/28748258/1776425831092-a66816a2-c96d-4698-95ae-8d29f9b41061.pdf

# ---------- 邮箱配置 ----------
# 资料发送的目标邮箱
SUBMIT_EMAIL=license@example.com
